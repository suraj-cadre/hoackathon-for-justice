# App
APP_NAME=contract-analyzer
ENV=dev
DEBUG=true

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=hackathon_db

# AWS SES
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_SENDER_EMAIL=Cadre ODR <no-reply@cadreodr.com>
SES_REPLY_TO_EMAIL=Cadre ODR <no-reply@cadreodr.com>

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_EMBED_MODEL=text-embedding-3-small

# Contract Analyzer
MAX_CONTRACT_SIZE_KB=500
